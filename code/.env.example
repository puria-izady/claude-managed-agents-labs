# Anthropic Managed Agents - labs env vars.
# Copy to `.env` and fill in real values. Never commit `.env`.

# Required for every lab (the SDK reads it automatically)
ANTHROPIC_API_KEY=sk-ant-...

# Labs 03 and 13 - Google Docs connection configured in Claude Managed Agents Vaults.
GOOGLE_DOCS_VAULT_ID=
# Optional override if the vault has multiple MCP credentials.
GOOGLE_DOCS_MCP_URL=

# Lab 06 - Linear MCP connection configured in Claude Managed Agents Vaults.
LINEAR_VAULT_ID=
# Optional override if the vault has multiple MCP credentials.
LINEAR_MCP_URL=

# Labs 06 and 13 - Slack MCP connection configured in Claude Managed Agents Vaults.
SLACK_VAULT_ID=
# Optional override if the vault has multiple MCP credentials.
SLACK_MCP_URL=
# Lab 13 - non-secret channel target for agent updates.
SLACK_CHANNEL=#research

# Lab 06 script-only fallback (advanced): create/register Linear from OAuth.
LINEAR_OAUTH_ACCESS_TOKEN=
LINEAR_OAUTH_REFRESH_TOKEN=
LINEAR_OAUTH_CLIENT_ID=
LINEAR_OAUTH_CLIENT_SECRET=
LINEAR_TOKEN_ENDPOINT=https://api.linear.app/oauth/token
LINEAR_EXPIRES_AT=
LINEAR_USER_LABEL=
LINEAR_EXTERNAL_USER_ID=

# Lab 12 - Bug-fixer + PR. Token attaches the repo; vault authenticates GitHub MCP.
GITHUB_TOKEN=github_pat_...
GITHUB_REPO_URL=https://github.com/your-org/your-repo
# Optional override; otherwise the preflight uses the repo default branch.
GITHUB_BRANCH=
GITHUB_VAULT_ID=
# Optional override if the vault has multiple MCP credentials.
GITHUB_MCP_URL=
