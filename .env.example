# Anthropic Managed Agents - labs env vars.
# Copy to `.env` and fill in real values. Never commit `.env`.

# Required for every lab (the SDK reads it automatically)
ANTHROPIC_API_KEY=sk-ant-...

# Labs 03 and 13 - Google Docs connection configured in Claude Managed Agents Vaults.
GOOGLE_DOCS_VAULT_ID=
# Optional override if the vault has multiple MCP credentials.
GOOGLE_DOCS_MCP_URL=

# Lab 06 - one vault containing both Linear and Slack MCP connections.
LINEAR_VAULT_ID=

# Labs 06 and 13 - non-secret channel target for agent updates.
SLACK_CHANNEL="#research"

# Lab 13 - Slack MCP connection configured in Claude Managed Agents Vaults.
SLACK_VAULT_ID=
# Optional override if the vault has multiple MCP credentials.
SLACK_MCP_URL=

# Lab 12 - Bug-fixer + PR. Token attaches the repo; vault authenticates GitHub MCP.
GITHUB_TOKEN=github_pat_...
GITHUB_REPO_URL=https://github.com/your-org/your-repo
# Optional override; otherwise the preflight uses the repo default branch.
GITHUB_BRANCH=
GITHUB_VAULT_ID=
# Optional override if the vault has multiple MCP credentials.
GITHUB_MCP_URL=
